# OpenAI 兼容协议 LLM 配置
# 复制此文件为 .env 并填写真实参数，.env 已被 .gitignore 排除，不会提交到仓库

# API 地址 (OpenAI 兼容协议端点)
LLM_BASE_URL=https://api.openai.com/v1

# API 密钥
LLM_API_KEY=sk-your-api-key-here

# 模型名称
LLM_MODEL=gpt-3.5-turbo

# 请求超时时间 (秒)
LLM_TIMEOUT=60

# 系统提示词 (可选)
LLM_SYSTEM_PROMPT=你是一个有帮助的AI助手。

# 生成参数优化（影响速度）
LLM_TEMPERATURE=0.3        # 温度越低，生成越快越确定（0-2）
LLM_MAX_TOKENS=512         # 最大输出token数，越小越快
LLM_TOP_P=0.9              # 采样概率，越小越快

# AnythingLLM 配置（用于查询本地知识库/文档仓库）
ANYTHINGLLM_API_KEY=your-anythingllm-api-key
ANYTHINGLLM_WORKSPACE_SLUG=your-workspace-slug
